{
  "query": "\nSELECT \n  ROW_NUMBER() OVER (ORDER BY g.nome ASC) AS numero,\n  g.nome,\n  COUNT(s.id) AS total_sessoes,\n  DATE_FORMAT(MIN(s.createdAt), '%d/%m/%Y') AS primeiro_acesso,\n  DATE_FORMAT(MAX(s.ultimoAcesso), '%d/%m/%Y') AS ultimo_acesso\nFROM sessoesGestante s\nJOIN gestantes g ON g.id = s.gestanteId\nGROUP BY g.id, g.nome\nORDER BY g.nome ASC\nLIMIT 35 OFFSET 20;\n",
